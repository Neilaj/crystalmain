generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatar       String?
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  site  Site?
  pages Page[]
}

enum Role {
  ADMIN
  EDITOR
}

// ─── Site ────────────────────────────────────────────

model Site {
  id          String  @id @default(cuid())
  name        String  @default("My Site")
  tagline     String?
  description String?
  domain      String? @unique
  logo        String?
  favicon     String?
  theme       String  @default("clean-blog")

  // Social links
  socialTwitter  String?
  socialLinkedin String?
  socialGithub   String?
  socialYoutube  String?

  // Footer
  footerText String?

  // Analytics
  analyticsSnippet String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Homepage content (editable from admin)
  homepageContent Json?

  // AI Video page content (editable from admin)
  aiVideoContent Json?

  // Enabled modules/features
  enabledFeatures String[] @default(["contact-form"])

  pages          Page[]
  hubs           Hub[]
  media          Media[]
  navigation     Navigation[]
  importHistory  ImportHistory[]
  contactForms   ContactForm[]
}

// ─── Hubs (Topic Clusters for SEO/AEO) ──────────────

model Hub {
  id          String @id @default(cuid())
  name        String                          // e.g., "Web Design"
  slug        String                          // e.g., "web-design"
  description String?                         // Hub topic description
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // The pillar page for this hub (optional — can be auto-generated)
  pillarPageId String? @unique
  pillarPage   Page?   @relation("HubPillar", fields: [pillarPageId], references: [id])

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // Spoke pages linked to this hub
  spokes Page[] @relation("HubSpokes")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, slug])
  @@index([siteId])
}

// ─── Pages ───────────────────────────────────────────

model Page {
  id     String @id @default(cuid())
  title  String
  slug   String
  status PageStatus @default(DRAFT)

  // Content stored as Tiptap JSON
  content Json?

  // Content type drives Schema.org structured data
  contentType ContentType @default(PAGE)

  // Optional collection for grouping (e.g., "Blog", "Services")
  collection String?

  // Hub relationships (topic clusters)
  hubId String?
  hub   Hub?    @relation("HubSpokes", fields: [hubId], references: [id], onDelete: SetNull)
  pillarForHub Hub? @relation("HubPillar")

  // SEO & AI fields
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  excerpt         String?

  // Import tracking
  importBatchId String?
  importBatch   ImportHistory? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  // Publishing
  publishedAt DateTime?
  sortOrder   Int       @default(0)

  // Relationships
  siteId   String
  site     Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([siteId, collection])
  @@index([hubId])
  @@index([importBatchId])
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContentType {
  PAGE
  ARTICLE
  FAQ
  LANDING
  SERVICE
  PRODUCT
  PORTFOLIO
  CONTACT
}

// ─── Media ───────────────────────────────────────────

model Media {
  id       String @id @default(cuid())
  url      String
  filename String
  alt      String @default("")
  caption  String?
  mimeType String
  size     Int    // bytes

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([siteId])
}

// ─── Import History ─────────────────────────────────

model ImportHistory {
  id          String       @id @default(cuid())
  source      String                               // e.g., "wordpress"
  sourceUrl   String                               // e.g., "https://oldsite.com"
  sourceName  String?                              // e.g., "My Old Blog"
  status      ImportStatus @default(COMPLETED)
  stagingMode Boolean      @default(false)         // true = imported as drafts

  // Stats
  totalItems     Int    @default(0)
  importedCount  Int    @default(0)
  skippedCount   Int    @default(0)
  mediaCount     Int    @default(0)

  // Detailed report stored as JSON
  report Json?

  // Hub IDs created during this import (for rollback)
  hubIds String[] @default([])

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // Pages created during this import
  pages Page[]

  createdAt DateTime @default(now())

  @@index([siteId])
}

enum ImportStatus {
  COMPLETED
  ROLLED_BACK
  PARTIAL
}

// ─── Contact Forms (Built-in Module) ─────────────────

model ContactForm {
  id          String @id @default(cuid())
  name        String                          // e.g., "Main Contact Form"
  slug        String                          // e.g., "contact" — used in URL /form/contact
  description String?

  // Form configuration
  fields      Json                            // Array of field definitions
  submitLabel String  @default("Send Message")
  successMessage String @default("Thank you! We'll get back to you soon.")

  // Email notification
  notifyEmail String?                         // Send notification to this email on submission

  // Anti-spam
  honeypotEnabled Boolean @default(true)

  // Schema.org
  schemaType  String  @default("ContactPage") // ContactPage, AskAction, etc.

  enabled Boolean @default(true)

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  submissions FormSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, slug])
  @@index([siteId])
}

model FormSubmission {
  id     String @id @default(cuid())
  data   Json                                 // Submitted form data as key-value pairs
  status SubmissionStatus @default(NEW)

  // Metadata
  ipAddress  String?
  userAgent  String?
  referrer   String?

  formId String
  form   ContactForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([formId])
  @@index([formId, status])
}

enum SubmissionStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

// ─── Navigation ──────────────────────────────────────

model Navigation {
  id       String @id @default(cuid())
  label    String
  url      String
  order    Int    @default(0)
  openNew  Boolean @default(false)
  location NavLocation @default(HEADER)

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([siteId, location])
}

enum NavLocation {
  HEADER
  FOOTER
  BOTH
}
